  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://purl.org/vocab/vann/example" : [ {
    "@value" : "\n        :my-fabio-item a fabio:Item ;\n            fabio:isStoredOn fabio:dvd .\n    "
