  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A version of the title of an entity translated into another language, which may be specified using the object property dcterms:language."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
