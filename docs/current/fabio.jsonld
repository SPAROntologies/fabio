  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://purl.org/vocab/vann/example" : [ {
    "@value" : "\n        :my-journal-article a fabio:JournalArticle ;\n            fabio:hasStandardNumber 'ISO 9001:2015' .\n    "
