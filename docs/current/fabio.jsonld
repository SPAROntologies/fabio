    "@value" : "\n        :my-journal-article a fabio:JournalArticle ;\n            fabio:hasTranslatedSubtitle 'Guida pratica alle ontologie e ai Linked Data'@it .\n    "
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A version of the subtitle of an entity translated into another language, which may be specified using the object property dcterms:language."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "http://purl.org/spar/fabio"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
