  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#topObjectProperty"
  } ],
  "http://www.w3.org/2003/06/sw-vocab-status/ns#term_status" : [ {
