  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.org/spar/fabio/Specification"
  } ],
  "http://www.w3.org/2003/06/sw-vocab-status/ns#term_status" : [ {
    "@language" : "en",
    "@value" : "stable"
  } ]
